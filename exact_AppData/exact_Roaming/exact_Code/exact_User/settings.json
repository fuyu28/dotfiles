  //////////////////////////////////////////////////////////
  // Extension - Tailwind CSS InteliSense
  //////////////////////////////////////////////////////////
  "files.associations": {
    "*.css": "tailwindcss"
  },

  //////////////////////////////////////////////////////////
  // Extension - Prisma
  //////////////////////////////////////////////////////////
  "[prisma]": {
    "editor.defaultFormatter": "Prisma.prisma"
  },
  //////////////////////////////////////////////////////////
  // Extension - Trailing Spaces
  //////////////////////////////////////////////////////////
  "trailing-spaces.trimOnSave": true,

  //////////////////////////////////////////////////////////
  // e.t.c.
  //////////////////////////////////////////////////////////
  "debug.onTaskErrors": "showErrors",
  "interactiveWindow.executeWithShiftEnter": true,
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "tsconfig.json": "tsconfig.*.json",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb",
    "*.sqlite": "${capture}.${extname}-*",
    "*.db": "${capture}.${extname}-*",
    "*.sqlite3": "${capture}.${extname}-*",
    "*.db3": "${capture}.${extname}-*",
    "*.sdb": "${capture}.${extname}-*",
    "*.s3db": "${capture}.${extname}-*"
  },
  "techtrain-railway.optOutTelemetry": false,
  "rubyLsp.rubyExecutablePath": "c:\\Ruby33-x64\\bin\\ruby.exe",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "editor.unicodeHighlight.allowedCharacters": {
    "．": true,
    "，": true
  },
  "database-client.autoSync": true,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "roo-cline.allowedCommands": [
    "npm test",
    "npm install",
    "tsc",
    "git log",
    "git diff",
    "git show",
    "md Task7A\\src\\jp\\ac\\meijo_u\\id241205178",
    "md Task7Asrcjpacmeijo_uid241205178",
    "md",
    "uv sync",
    "cd",
    "cd remove-blindfold",
    "cd remove-blindfold && uv sync",
    "uv run",
    "mkdir",
    "copy",
    "del",
    "mvn",
    "Remove-Item",
    "javac",
    "java"
  ],
  "roo-cline.deniedCommands": [],
  "python.analysis.typeCheckingMode": "standard",
  "update.showReleaseNotes": false
}
