# まず広い場所を全ブロック
{{ if eq .chezmoi.os "linux" -}}
# Linux環境ではAppDataを無視
AppData/**
{{ end -}}
.appdata/**
.config/**

# ---- 親→子の順で穴あけ ----

{{ if eq .chezmoi.os "windows" -}}
# AppData/Roaming/Code/User（VSCode）
!AppData
!AppData/Roaming
!AppData/Roaming/Code
!AppData/Roaming/Code/User
!AppData/Roaming/Code/User/settings.json
!AppData/Roaming/Code/User/keybindings.json
!AppData/Roaming/Code/User/snippets/**

# AppData/Roaming/nushell
!AppData/Roaming/nushell
!AppData/Roaming/nushell/config.nu
!AppData/Roaming/nushell/env.nu

# AppData/Local（NeoVim / VSCode NeoVim / clink）
!AppData/Local
!AppData/Local/nvim/**
!AppData/Local/nvim-vscode/**
!AppData/Local/clink
!AppData/Local/clink/starship.lua
{{ end -}}

# .config（wezterm / starship.toml）
!.config
!.config/wezterm
!.config/wezterm/**
!.config/starship.toml

# ルート直下（LaTeX）
!.chktexrc
!.latexmkrc

# ============================================
# Linux環境用の除外設定
# ============================================

# セキュリティリスクのあるファイルを除外
.bash_history
.viminfo
.Xauthority
.claude.json*
.git-credentials
.lesshst
.wget-hsts
.sudo_as_admin_successful

# キャッシュ・一時ファイル
.cache/**
.local/share/**
.local/state/**

# アプリケーションデータ（認証情報を含む可能性）
.config/discord/**
.config/spotify/**
.config/Bitwarden/**
.config/BraveSoftware/**
.config/Electron/**
.config/Code/**
.config/zoom.conf
.config/zoomus.conf
.config/dconf/**
.config/pulse/**
.config/systemd/**
.config/QtProject.conf

{{ if eq .chezmoi.os "windows" -}}
# Windows環境ではLinux固有のdotfilesを無視
.bashrc
.bash_profile
.bash_logout
.xinitrc
.xprofile
.Xresources
.gtkrc-2.0
.dmenurc
.fehbg
.dir_colors
.makepkg.conf
pacman-aur.txt
pacman-explicit.txt
{{ else -}}
# ルートディレクトリのdotfiles（Linux）
!.bashrc
!.bash_profile
!.bash_logout
!.profile
!.zshrc
!.zshenv
!.zprofile
!.zlogin
!.zlogout
!.xinitrc
!.xprofile
!.Xresources
!.gtkrc-2.0
!.dmenurc
!.fehbg
!.dir_colors
!.makepkg.conf
!pacman-aur.txt
!pacman-explicit.txt
{{ end -}}

# 全環境で必要なファイル
!.gitconfig
!.chktexrc
!.latexmkrc

