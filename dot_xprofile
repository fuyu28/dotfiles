# fcitx5
export GTK_IM_MODULE=fcitx5
export QT_IM_MODULE=fcitx5
export XMODIFIERS=@im=fcitx5

fcitx5 --replace -d

# キー配置を日本語に固定（106キーボード）
# -option ""でグループ切り替えオプション(grp:alt_shift_toggle)を無効化
# setxkbmap -model pc106 -layout jp -option ""

# デスクトップ偽装（GTK にダークテーマを使わせる）
export XDG_CURRENT_DESKTOP=GNOME

# PORTAL の有効化（Slack 外部ブラウザ対応）
export GTK_USE_PORTAL=1

# Portal backends の起動（i3 は自動起動しない）
/usr/lib/xdg-desktop-portal &
/usr/lib/xdg-desktop-portal-gtk &

# XDG_DATA_DIRS の補完（Flatpak / icons / themes の検索パス）
export XDG_DATA_DIRS="/home/fuyu/.local/share/flatpak/exports/share:/var/lib/flatpak/exports/share:/usr/local/share:/usr/share"
